name: Update Core

permissions:
  contents: write

on:
  workflow_dispatch:
    inputs:
      projects:
        description: '要更新的项目 (逗号分隔: sing-box,mihomo 或 all)'
        required: false
        default: 'all'
      force_update:
        description: '强制更新（忽略版本检查）'
        required: false
        type: boolean
        default: false

  schedule:
    - cron: "0 18 * * *"

  push:
    branches:
      - main
    paths:
      # 只有这些核心文件变动才触发，避免 README 等无关改动误触发
      - '.github/workflows/update-core.yml'
      - '.github/workflows/build-go-project.yml'
      - '.github/workflows/download-binaries.yml'
      - '.github/scripts/**'

jobs:
  # ========================================================================
  # 准备阶段：获取 Go 版本
  # ========================================================================
  prepare:
    name: 准备构建环境
    runs-on: ubuntu-latest
    outputs:
      go_version: ${{ steps.go.outputs.version }}

    steps:
      - name: 获取最新 Go 版本
        id: go
        run: |
          version=$(curl -sSL https://raw.githubusercontent.com/actions/go-versions/update-versions-manifest-file/versions-manifest.json | \
                    jq -r '.[0].version')
          echo "version=${version}" >> $GITHUB_OUTPUT

  # ========================================================================
  # sing-box 版本检测（修复：使用 GitHub Release API 获取版本，修复 GITHUB_OUTPUT 写入）
  # ========================================================================
  check-singbox:
    name: 检测 sing-box 版本
    runs-on: ubuntu-latest
    if: |
      github.event.inputs.projects == 'all' ||
      github.event.inputs.projects == 'sing-box' ||
      github.event_name != 'workflow_dispatch'

    outputs:
      ref1nd_main_version:        ${{ steps.versions.outputs.ref1nd_main_version }}
      ref1nd_main_tags:           ${{ steps.versions.outputs.ref1nd_main_tags }}
      ref1nd_main_skip:           ${{ steps.compare.outputs.ref1nd_main_skip }}

      ref1nd_dev_version:         ${{ steps.versions.outputs.ref1nd_dev_version }}
      ref1nd_dev_tags:            ${{ steps.versions.outputs.ref1nd_dev_tags }}
      ref1nd_dev_skip:            ${{ steps.compare.outputs.ref1nd_dev_skip }}

      sagernet_release_version:   ${{ steps.versions.outputs.sagernet_release_version }}
      sagernet_release_tags:      ${{ steps.versions.outputs.sagernet_release_tags }}
      sagernet_release_skip:      ${{ steps.compare.outputs.sagernet_release_skip }}

      sagernet_dev_version:       ${{ steps.versions.outputs.sagernet_dev_version }}
      sagernet_dev_tags:          ${{ steps.versions.outputs.sagernet_dev_tags }}
      sagernet_dev_skip:          ${{ steps.compare.outputs.sagernet_dev_skip }}

    steps:
      # ------------------------------------------------------------------
      # 修复：sing-box 版本从对应的 GitHub Release API 获取，
      #       不再使用 git clone --depth=1 + git tag（depth=1 拉不到 tag）
      # ------------------------------------------------------------------
      - name: 获取各 sing-box 变体版本
        id: versions
        run: |
          # reF1nd-main: 从 reF1nd/sing-box-releases 最新正式版获取
          REF1ND_MAIN_VER=$(curl -sSL https://api.github.com/repos/reF1nd/sing-box-releases/releases/latest \
                            | jq -r '.tag_name // "unknown"' | sed 's/^v//')
          echo "ref1nd_main_version=${REF1ND_MAIN_VER}" >> $GITHUB_OUTPUT
          echo "ref1nd_main_tags=with_gvisor,with_quic,with_dhcp,with_utls,with_clash_api" >> $GITHUB_OUTPUT

          # reF1nd-dev: 从 reF1nd/sing-box-releases 最新预发布版获取
          REF1ND_DEV_VER=$(curl -sSL https://api.github.com/repos/reF1nd/sing-box-releases/releases \
                           | jq -r '[.[] | select(.prerelease==true)][0].tag_name // "unknown"' | sed 's/^v//')
          echo "ref1nd_dev_version=${REF1ND_DEV_VER}" >> $GITHUB_OUTPUT
          echo "ref1nd_dev_tags=with_gvisor,with_quic,with_dhcp,with_utls,with_clash_api" >> $GITHUB_OUTPUT

          # SagerNet-release
          SAGERNET_REL_VER=$(curl -sSL https://api.github.com/repos/SagerNet/sing-box/releases/latest \
                             | jq -r '.tag_name // "unknown"' | sed 's/^v//')
          echo "sagernet_release_version=${SAGERNET_REL_VER}" >> $GITHUB_OUTPUT
          echo "sagernet_release_tags=with_gvisor,with_quic,with_dhcp,with_utls,with_clash_api" >> $GITHUB_OUTPUT

          # SagerNet-dev
          SAGERNET_DEV_VER=$(curl -sSL https://api.github.com/repos/SagerNet/sing-box/releases \
                             | jq -r '[.[] | select(.prerelease==true)][0].tag_name // "unknown"' | sed 's/^v//')
          echo "sagernet_dev_version=${SAGERNET_DEV_VER}" >> $GITHUB_OUTPUT
          echo "sagernet_dev_tags=with_gvisor,with_quic,with_dhcp,with_utls,with_clash_api" >> $GITHUB_OUTPUT

          echo "✅ ref1nd-main:       ${REF1ND_MAIN_VER}"
          echo "✅ ref1nd-dev:        ${REF1ND_DEV_VER}"
          echo "✅ sagernet-release:  ${SAGERNET_REL_VER}"
          echo "✅ sagernet-dev:      ${SAGERNET_DEV_VER}"

      # ------------------------------------------------------------------
      # 修复：版本比对逻辑
      #   1. 所有 echo 均带 >> $GITHUB_OUTPUT（原代码遗漏）
      #   2. force_update=true 时全部强制重建
      #   3. 否则读取已发布 Release body，判断版本+日期是否已存在
      # ------------------------------------------------------------------
      - name: 版本比对
        id: compare
        run: |
          FORCE="${{ github.event.inputs.force_update }}"

          # 读取当前已发布的 sing-box Release body（用于版本去重）
          CURRENT_BODY=$(curl -sSL \
            "https://api.github.com/repos/${{ github.repository }}/releases/tags/sing-box" \
            | jq -r '.body // ""')

          check_skip() {
            local key="$1"     # 输出变量名前缀，如 ref1nd_main
            local ver="$2"     # 版本字符串
            local label="$3"   # Release body 中的显示名，如 "sing-box reF1nd-main"

            if [[ "$FORCE" == "true" ]]; then
              echo "${key}_skip=false" >> $GITHUB_OUTPUT
              echo "🔨 ${label}: 强制重建 ${ver}"
              return
            fi

            if [[ "$ver" == "unknown" || -z "$ver" ]]; then
              echo "${key}_skip=true" >> $GITHUB_OUTPUT
              echo "⚠️  ${label}: 版本获取失败，跳过"
              return
            fi

            if echo "${CURRENT_BODY}" | grep -q "${label}.*${ver}"; then
              echo "${key}_skip=true" >> $GITHUB_OUTPUT
              echo "✅ ${label}: 已是最新 ${ver}，跳过"
            else
              echo "${key}_skip=false" >> $GITHUB_OUTPUT
              echo "🆕 ${label}: 需要更新至 ${ver}"
            fi
          }

          check_skip "ref1nd_main"      "${{ steps.versions.outputs.ref1nd_main_version }}"      "sing-box reF1nd-main"
          check_skip "ref1nd_dev"       "${{ steps.versions.outputs.ref1nd_dev_version }}"       "sing-box reF1nd-dev"
          check_skip "sagernet_release" "${{ steps.versions.outputs.sagernet_release_version }}" "sing-box SagerNet-release"
          check_skip "sagernet_dev"     "${{ steps.versions.outputs.sagernet_dev_version }}"     "sing-box SagerNet-dev"

  # ========================================================================
  # mihomo 版本检测（修复：版本比对逻辑对齐参考项目）
  # ========================================================================
  check-mihomo:
    name: 检测 mihomo 版本
    runs-on: ubuntu-latest
    if: |
      github.event.inputs.projects == 'all' ||
      github.event.inputs.projects == 'mihomo' ||
      github.event_name != 'workflow_dispatch'

    outputs:
      meta_version:  ${{ steps.versions.outputs.meta_version }}
      meta_skip:     ${{ steps.compare.outputs.meta_skip }}

      alpha_version: ${{ steps.versions.outputs.alpha_version }}
      alpha_skip:    ${{ steps.compare.outputs.alpha_skip }}

      smart_version: ${{ steps.versions.outputs.smart_version }}
      smart_skip:    ${{ steps.compare.outputs.smart_skip }}

    steps:
      - name: 获取各 mihomo 变体版本
        id: versions
        run: |
          # Meta 正式版
          META_VER=$(curl -sSL https://api.github.com/repos/MetaCubeX/mihomo/releases/latest \
                     | jq -r '.tag_name // ""')
          if [[ -n "$META_VER" && "$META_VER" != "null" ]]; then
            echo "meta_version=${META_VER}" >> $GITHUB_OUTPUT
            echo "✅ Meta Release: ${META_VER}"
          else
            echo "meta_version=" >> $GITHUB_OUTPUT
            echo "⚠️  Meta Release: 获取失败"
          fi

          # Alpha 版：从 version.txt 获取精确版本字符串（如 alpha-xxxxxxx）
          ALPHA_VER=$(curl -sSL \
            https://github.com/MetaCubeX/mihomo/releases/download/Prerelease-Alpha/version.txt \
            | tr -d '[:space:]')
          if [[ -n "$ALPHA_VER" ]]; then
            echo "alpha_version=${ALPHA_VER}" >> $GITHUB_OUTPUT
            echo "✅ Meta Alpha: ${ALPHA_VER}"
          else
            echo "alpha_version=" >> $GITHUB_OUTPUT
            echo "⚠️  Meta Alpha: version.txt 为空"
          fi

          # Smart 版：从 version.txt 获取精确版本字符串
          SMART_VER=$(curl -sSL \
            https://github.com/vernesong/mihomo/releases/download/Prerelease-Alpha/version.txt \
            | tr -d '[:space:]')
          if [[ -n "$SMART_VER" ]]; then
            echo "smart_version=${SMART_VER}" >> $GITHUB_OUTPUT
            echo "✅ Smart Alpha: ${SMART_VER}"
          else
            echo "smart_version=" >> $GITHUB_OUTPUT
            echo "⚠️  Smart Alpha: version.txt 为空"
          fi

      - name: 版本比对
        id: compare
        run: |
          FORCE="${{ github.event.inputs.force_update }}"

          CURRENT_BODY=$(curl -sSL \
            "https://api.github.com/repos/${{ github.repository }}/releases/tags/mihomo" \
            | jq -r '.body // ""')

          check_skip() {
            local key="$1"
            local ver="$2"
            local label="$3"

            if [[ "$FORCE" == "true" ]]; then
              echo "${key}_skip=false" >> $GITHUB_OUTPUT
              echo "🔨 ${label}: 强制重建 ${ver}"
              return
            fi

            if [[ -z "$ver" ]]; then
              echo "${key}_skip=true" >> $GITHUB_OUTPUT
              echo "⚠️  ${label}: 版本获取失败，跳过"
              return
            fi

            if echo "${CURRENT_BODY}" | grep -q "${label}.*${ver}"; then
              echo "${key}_skip=true" >> $GITHUB_OUTPUT
              echo "✅ ${label}: 已是最新 ${ver}，跳过"
            else
              echo "${key}_skip=false" >> $GITHUB_OUTPUT
              echo "🆕 ${label}: 需要更新至 ${ver}"
            fi
          }

          check_skip "meta"  "${{ steps.versions.outputs.meta_version }}"  "mihomo Meta"
          check_skip "alpha" "${{ steps.versions.outputs.alpha_version }}" "mihomo Alpha"
          check_skip "smart" "${{ steps.versions.outputs.smart_version }}" "mihomo Smart"

  # ========================================================================
  # sing-box 构建任务（调用可复用 workflow）
  # ========================================================================
  build-singbox-ref1nd-main:
    name: 构建 sing-box reF1nd-main
    needs: [prepare, check-singbox]
    if: needs.check-singbox.outputs.ref1nd_main_skip != 'true'
    uses: ./.github/workflows/build-go-project.yml
    with:
      project: sing-box
      variant: ref1nd-main
      version: ${{ needs.check-singbox.outputs.ref1nd_main_version }}
      build_tags: ${{ needs.check-singbox.outputs.ref1nd_main_tags }}
      go_version: ${{ needs.prepare.outputs.go_version }}

  build-singbox-ref1nd-dev:
    name: 构建 sing-box reF1nd-dev
    needs: [prepare, check-singbox]
    if: needs.check-singbox.outputs.ref1nd_dev_skip != 'true'
    uses: ./.github/workflows/build-go-project.yml
    with:
      project: sing-box
      variant: ref1nd-dev
      version: ${{ needs.check-singbox.outputs.ref1nd_dev_version }}
      build_tags: ${{ needs.check-singbox.outputs.ref1nd_dev_tags }}
      go_version: ${{ needs.prepare.outputs.go_version }}

  build-singbox-sagernet-release:
    name: 构建 sing-box SagerNet-release
    needs: [prepare, check-singbox]
    if: needs.check-singbox.outputs.sagernet_release_skip != 'true'
    uses: ./.github/workflows/build-go-project.yml
    with:
      project: sing-box
      variant: sagernet-release
      version: ${{ needs.check-singbox.outputs.sagernet_release_version }}
      build_tags: ${{ needs.check-singbox.outputs.sagernet_release_tags }}
      go_version: ${{ needs.prepare.outputs.go_version }}

  build-singbox-sagernet-dev:
    name: 构建 sing-box SagerNet-dev
    needs: [prepare, check-singbox]
    if: needs.check-singbox.outputs.sagernet_dev_skip != 'true'
    uses: ./.github/workflows/build-go-project.yml
    with:
      project: sing-box
      variant: sagernet-dev
      version: ${{ needs.check-singbox.outputs.sagernet_dev_version }}
      build_tags: ${{ needs.check-singbox.outputs.sagernet_dev_tags }}
      go_version: ${{ needs.prepare.outputs.go_version }}

  # ========================================================================
  # mihomo 下载任务（调用可复用 workflow）
  # ========================================================================
  download-mihomo-meta:
    name: 下载 mihomo Meta
    needs: [check-mihomo]
    if: needs.check-mihomo.outputs.meta_skip != 'true'
    uses: ./.github/workflows/download-binaries.yml
    with:
      project: mihomo
      variant: meta
      version: ${{ needs.check-mihomo.outputs.meta_version }}

  download-mihomo-alpha:
    name: 下载 mihomo Alpha
    needs: [check-mihomo]
    if: needs.check-mihomo.outputs.alpha_skip != 'true'
    uses: ./.github/workflows/download-binaries.yml
    with:
      project: mihomo
      variant: alpha
      version: ${{ needs.check-mihomo.outputs.alpha_version }}

  download-mihomo-smart:
    name: 下载 mihomo Smart
    needs: [check-mihomo]
    if: needs.check-mihomo.outputs.smart_skip != 'true'
    uses: ./.github/workflows/download-binaries.yml
    with:
      project: mihomo
      variant: smart
      version: ${{ needs.check-mihomo.outputs.smart_version }}

  # ========================================================================
  # 产物收集、UPX 压缩、发布到 core 分支 + GitHub Release
  # ========================================================================
  publish:
    name: 发布到 Core 分支
    runs-on: ubuntu-latest
    needs:
      - check-singbox
      - check-mihomo
      - build-singbox-ref1nd-main
      - build-singbox-ref1nd-dev
      - build-singbox-sagernet-release
      - build-singbox-sagernet-dev
      - download-mihomo-meta
      - download-mihomo-alpha
      - download-mihomo-smart
    # always() 保证无论上游 job 是 skipped/success/failure 都能到这里
    # 但只有在没有真正失败（failure）时才实际执行有意义的工作
    if: always()

    env:
      # 把各变体的 skip 标志引入，供后续步骤判断 Release body 要不要更新
      REF1ND_MAIN_VER:      ${{ needs.check-singbox.outputs.ref1nd_main_version }}
      REF1ND_MAIN_SKIP:     ${{ needs.check-singbox.outputs.ref1nd_main_skip }}
      REF1ND_DEV_VER:       ${{ needs.check-singbox.outputs.ref1nd_dev_version }}
      REF1ND_DEV_SKIP:      ${{ needs.check-singbox.outputs.ref1nd_dev_skip }}
      SAGERNET_REL_VER:     ${{ needs.check-singbox.outputs.sagernet_release_version }}
      SAGERNET_REL_SKIP:    ${{ needs.check-singbox.outputs.sagernet_release_skip }}
      SAGERNET_DEV_VER:     ${{ needs.check-singbox.outputs.sagernet_dev_version }}
      SAGERNET_DEV_SKIP:    ${{ needs.check-singbox.outputs.sagernet_dev_skip }}
      META_VER:             ${{ needs.check-mihomo.outputs.meta_version }}
      META_SKIP:            ${{ needs.check-mihomo.outputs.meta_skip }}
      ALPHA_VER:            ${{ needs.check-mihomo.outputs.alpha_version }}
      ALPHA_SKIP:           ${{ needs.check-mihomo.outputs.alpha_skip }}
      SMART_VER:            ${{ needs.check-mihomo.outputs.smart_version }}
      SMART_SKIP:           ${{ needs.check-mihomo.outputs.smart_skip }}

    steps:
      - name: 下载所有产物
        uses: actions/download-artifact@v8
        with:
          path: ./artifacts
          merge-multiple: true

      - name: 检查是否有新产物
        id: check
        run: |
          count=$(find ./artifacts -type f | wc -l)
          echo "artifact_count=${count}" >> $GITHUB_OUTPUT
          if [[ "$count" -gt 0 ]]; then
            echo "has_artifacts=true" >> $GITHUB_OUTPUT
            echo "✅ 发现 ${count} 个产物文件，继续处理"
          else
            echo "has_artifacts=false" >> $GITHUB_OUTPUT
            echo "ℹ️  没有新产物（所有变体均已是最新版本），跳过发布"
          fi

      - name: Setup UPX
        if: steps.check.outputs.has_artifacts == 'true'
        uses: crazy-max/ghaction-upx@v4
        with:
          version: latest
          install-only: true

      - name: UPX 压缩 Linux 二进制（标记为 .upx 的文件）
        if: steps.check.outputs.has_artifacts == 'true'
        run: |
          find ./artifacts -name "*.upx" -type f | while read f; do
            echo "压缩: $f"
            upx --best --lzma "$f" 2>/dev/null || echo "⚠️  UPX 跳过: $f（可能已压缩或不支持）"
          done

      - name: 整理产物目录结构
        if: steps.check.outputs.has_artifacts == 'true'
        run: |
          mkdir -p ./publish

          prepare_dir() { mkdir -p "./publish/$1"; }
          prepare_dir "sing-box/reF1nd/main"
          prepare_dir "sing-box/reF1nd/dev"
          prepare_dir "sing-box/SagerNet/release"
          prepare_dir "sing-box/SagerNet/dev"
          prepare_dir "mihomo/MetaCubeX/meta"
          prepare_dir "mihomo/MetaCubeX/alpha"
          prepare_dir "mihomo/vernesong/smart"

          echo "--- 处理 sing-box 产物 ---"
          for file in ./artifacts/sing-box-*; do
            [[ -f "$file" ]] || continue
            filename=$(basename "$file")
            # 文件名格式由 artifact-handler.sh 决定，这里匹配：
            # sing-box-{variant}-{platform}-{arch}.{ext}
            if [[ "$filename" =~ ^sing-box-([^-]+-[^-]+)-(.+)\.(tar\.gz|upx|exe)$ ]]; then
              variant="${BASH_REMATCH[1]}"
              rest="${BASH_REMATCH[2]}.${BASH_REMATCH[3]}"
              case "$variant" in
                ref1nd-main)      dest="sing-box/reF1nd/main" ;;
                ref1nd-dev)       dest="sing-box/reF1nd/dev" ;;
                sagernet-release) dest="sing-box/SagerNet/release" ;;
                sagernet-dev)     dest="sing-box/SagerNet/dev" ;;
                *)
                  echo "⚠️  未知 variant: $variant，文件：$filename"
                  continue
                  ;;
              esac
              cp "$file" "./publish/$dest/$filename"
              echo "✅ $filename → $dest"
            else
              echo "⚠️  文件名不匹配，跳过: $filename"
            fi
          done

          echo "--- 处理 mihomo 产物 ---"
          for file in ./artifacts/mihomo-*; do
            [[ -f "$file" ]] || continue
            filename=$(basename "$file")
            if [[ "$filename" =~ ^mihomo-([^-]+)-(.+)\.(tar\.gz|upx|exe)$ ]]; then
              variant="${BASH_REMATCH[1]}"
              case "$variant" in
                meta)  dest="mihomo/MetaCubeX/meta" ;;
                alpha) dest="mihomo/MetaCubeX/alpha" ;;
                smart) dest="mihomo/vernesong/smart" ;;
                *)
                  echo "⚠️  未知 variant: $variant，文件：$filename"
                  continue
                  ;;
              esac
              cp "$file" "./publish/$dest/$filename"
              echo "✅ $filename → $dest"
            else
              echo "⚠️  文件名不匹配，跳过: $filename"
            fi
          done

          echo "--- 产物汇总 ---"
          find ./publish -type f | sort

      - name: 生成 Checksum 和 README
        if: steps.check.outputs.has_artifacts == 'true'
        run: |
          cd ./publish
          find . -type f \( -name "*.tar.gz" -o -name "*.exe" -o -name "*.upx" \) \
            -exec sha256sum {} \; | sort > global_checksums.txt

          cat > README.md <<EOF
          # Core 核心文件仓库

          自动构建更新。最后更新：$(date -u '+%Y-%m-%d %H:%M:%S UTC')

          ## sing-box

          | 变体 | 版本 |
          |------|------|
          | reF1nd-main     | ${REF1ND_MAIN_VER} |
          | reF1nd-dev      | ${REF1ND_DEV_VER} |
          | SagerNet-release | ${SAGERNET_REL_VER} |
          | SagerNet-dev    | ${SAGERNET_DEV_VER} |

          ## mihomo

          | 变体 | 版本 |
          |------|------|
          | MetaCubeX Meta  | ${META_VER} |
          | MetaCubeX Alpha | ${ALPHA_VER} |
          | vernesong Smart | ${SMART_VER} |
          EOF

      - name: 推送到 core 分支
        if: steps.check.outputs.has_artifacts == 'true'
        run: |
          cd ./publish || exit 1
          git init
          git config --local user.name "github-actions[bot]"
          git config --local user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git checkout -b core
          git add .
          git commit -m "Update Cores: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"
          git remote add origin "https://${{ github.actor }}:${{ secrets.GITHUB_TOKEN }}@github.com/${{ github.repository }}"
          git push -f origin core

      # ------------------------------------------------------------------
      # 生成 Release body（只写入本次实际有更新的变体）
      # 格式与版本比对的 grep 模式对应，实现精确去重
      # ------------------------------------------------------------------
      - name: 生成 Release body 并发布
        if: steps.check.outputs.has_artifacts == 'true'
        run: |
          # 读取当前已有的 Release body 作为基础（首次为空）
          OLD_BODY=$(curl -sSL \
            "https://api.github.com/repos/${{ github.repository }}/releases/tags/cores" \
            | jq -r '.body // ""')

          NEW_BODY="$OLD_BODY"

          # 辅助函数：如果该变体有更新，追加/替换对应行
          upsert_line() {
            local skip="$1"
            local label="$2"   # 比对用标签，需与 check 阶段 grep 模式一致
            local ver="$3"
            local url="$4"

            [[ "$skip" == "true" ]] && return

            # 先移除旧行，再追加新行（实现"更新"语义）
            NEW_BODY=$(echo "$NEW_BODY" | grep -v "^${label}" || true)
            NEW_BODY="${NEW_BODY}"$'\n'"${label}: [${ver}](${url})"
          }

          upsert_line "$REF1ND_MAIN_SKIP"   "sing-box reF1nd-main"      "$REF1ND_MAIN_VER"  "https://github.com/reF1nd/sing-box-releases"
          upsert_line "$REF1ND_DEV_SKIP"    "sing-box reF1nd-dev"       "$REF1ND_DEV_VER"   "https://github.com/reF1nd/sing-box-releases"
          upsert_line "$SAGERNET_REL_SKIP"  "sing-box SagerNet-release" "$SAGERNET_REL_VER" "https://github.com/SagerNet/sing-box"
          upsert_line "$SAGERNET_DEV_SKIP"  "sing-box SagerNet-dev"     "$SAGERNET_DEV_VER" "https://github.com/SagerNet/sing-box"
          upsert_line "$META_SKIP"          "mihomo Meta"               "$META_VER"         "https://github.com/MetaCubeX/mihomo"
          upsert_line "$ALPHA_SKIP"         "mihomo Alpha"              "$ALPHA_VER"        "https://github.com/MetaCubeX/mihomo"
          upsert_line "$SMART_SKIP"         "mihomo Smart"              "$SMART_VER"        "https://github.com/vernesong/mihomo"

          # 写入文件供上传 action 使用
          echo "$NEW_BODY" > /tmp/release_body.txt

          # 使用 GitHub API 创建或更新 Release（tag: cores）
          RELEASE_ID=$(curl -sSL \
            -H "Authorization: token ${{ secrets.GITHUB_TOKEN }}" \
            "https://api.github.com/repos/${{ github.repository }}/releases/tags/cores" \
            | jq -r '.id // ""')

          BODY_JSON=$(jq -Rs '.' /tmp/release_body.txt)

          if [[ -n "$RELEASE_ID" ]]; then
            # 更新已有 Release
            curl -sSL -X PATCH \
              -H "Authorization: token ${{ secrets.GITHUB_TOKEN }}" \
              -H "Content-Type: application/json" \
              "https://api.github.com/repos/${{ github.repository }}/releases/${RELEASE_ID}" \
              -d "{\"body\": ${BODY_JSON}}"
            echo "✅ Release body 已更新"
          else
            # 首次创建 Release
            curl -sSL -X POST \
              -H "Authorization: token ${{ secrets.GITHUB_TOKEN }}" \
              -H "Content-Type: application/json" \
              "https://api.github.com/repos/${{ github.repository }}/releases" \
              -d "{\"tag_name\": \"cores\", \"name\": \"Core 版本记录\", \"body\": ${BODY_JSON}}"
            echo "✅ Release 已创建"
          fi

      - name: 清理旧 Workflow 记录
        uses: Mattraks/delete-workflow-runs@v2
        with:
          token: ${{ secrets.GITHUB_TOKEN }}
          repository: ${{ github.repository }}
          retain_days: 3
          keep_minimum_runs: 1
